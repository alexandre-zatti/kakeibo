# Database
# Local development with docker-compose.dev.yml
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kakeibo"

# Compose production stack
# These values are configured in Coolify. Do not commit real production values.
POSTGRES_USER="kakeibo"
POSTGRES_PASSWORD=""
POSTGRES_DB="kakeibo"

# Note: The app uses the "kakeibo" schema, not the default "public" schema.

# Better Auth
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here-change-this-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# For client-side auth
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Public URL used by the Coolify compose stack.
# Example: https://kakeibo.zatti.tech
KAKEIBO_PUBLIC_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Google Gemini API (for receipt scanning)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY="your-gemini-api-key-here"

# Google OAuth 2.0 (for finance adapters - Gmail/Drive access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WAHA internal WhatsApp service
# Generate plain key: uuidgen | tr -d '-'
# Generate hash: echo -n "$WAHA_API_KEY_PLAIN" | shasum -a 512
WAHA_BASE_URL="http://waha:3000"
WAHA_API_KEY_PLAIN=""
WAHA_API_KEY_HASH="sha512:"
WAHA_DASHBOARD_USERNAME="admin"
WAHA_DASHBOARD_PASSWORD=""
WAHA_SWAGGER_USERNAME="admin"
WAHA_SWAGGER_PASSWORD=""
WHATSAPP_CONSUMER_PORT="8788"
KAKEIBO_WHATSAPP_SESSION="default"
KAKEIBO_WHATSAPP_DEFAULT_CHAT_ID=""
KAKEIBO_WHATSAPP_DEFAULT_USER_ID=""

# Internal Codex runner
CODEX_RUNNER_BASE_URL="http://codex-runner:8787"
CODEX_RUNNER_TOKEN=""
CODEX_DEFAULT_MODEL="gpt-5.4"
CODEX_DEFAULT_SANDBOX="read-only"
CODEX_JOB_TIMEOUT_MS="300000"
CODEX_MAX_PROMPT_BYTES="200000"
CODEX_MAX_OUTPUT_BYTES="2000000"

# Internal Kakeibo webhooks
KAKEIBO_INTERNAL_WEBHOOK_SECRET=""
